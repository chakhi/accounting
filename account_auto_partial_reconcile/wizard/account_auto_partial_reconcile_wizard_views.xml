<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_auto_partial_reconcile_wizard" model="ir.ui.view">
        <field name="name">account.auto.partial.reconcile.wizard.form</field>
        <field name="model">account.auto.partial.reconcile.wizard</field>
        <field name="arch" type="xml">
            <form string="Rapprochement auto (partiel)">
                <field name="company_id" invisible="1"/>
                <field name="source_line_ids" invisible="1"/>
                <field name="available_payment_line_ids" invisible="1"/>
                <field name="available_counterpart_line_ids" invisible="1"/>

                <group>
                    <group>
                        <field name="payment_line_id" options="{'no_create': True, 'no_edit': True}"/>
                        <field name="partner_id" readonly="1"/>
                        <field name="account_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="payment_residual" readonly="1"/>
                        <field name="total_allocated_amount" readonly="1"/>
                        <field name="remaining_amount" readonly="1"/>
                    </group>
                </group>

                <separator string="Lignes d allocation"/>
                <field name="allocation_line_ids" nolabel="1">
                    <list editable="bottom">
                        <field name="wizard_id" column_invisible="1"/>
                        <field name="counterpart_line_id"
                               domain="[('id', 'in', parent.available_counterpart_line_ids)]"
                               options="{'no_create': True, 'no_edit': True}"/>
                        <field name="max_amount" readonly="1"/>
                        <field name="amount"/>
                    </list>
                </field>

                <separator string="Pieces comptables liees"/>
                <field name="available_counterpart_line_ids" nolabel="1" readonly="1">
                    <list create="false" edit="false" delete="false">
                        <field name="date"/>
                        <field name="move_name" string="Ecriture comptable"/>
                        <field name="name"/>
                        <field name="partner_id"/>
                        <field name="account_id"/>
                        <field name="amount_residual" string="Residuel"/>
                    </list>
                </field>

                <footer>
                    <button string="Rapprocher" name="action_partial_reconcile" type="object" class="btn-primary"/>
                    <button string="Annuler" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_open_auto_partial_reconcile_wizard" model="ir.actions.act_window">
        <field name="name">Rapprochement auto (partiel)</field>
        <field name="res_model">account.auto.partial.reconcile.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_account_auto_partial_reconcile_wizard"/>
        <field name="target">new</field>
    </record>
</odoo>
